    {
      "code": "SECURITY_BYPASS_REQUEST",
      "pattern": "\\b(bypass|crack|break)\\s+(?:the\\s+)?(?:wpa3|wpa2|wifi|wi-?fi|2fa|mfa|authentication|auth|password|captcha|firewall|antivirus|edr|encryption)\\b"
    },
    {
