{
  "injection_patterns": [
    {
      "code": "INSTRUCTION_OVERRIDE",
      "pattern": "\\b(ignore|disregard|override|forget|erase|discard)\\s+(?:all\\s+)?(?:the\\s+)?(?:previous|prior|earlier|past|preceding|above)\\s+instructions\\b"
    },
    {
      "code": "INSTRUCTION_IGNORE_FOLLOWING",
      "pattern": "\\b(ignore|disregard|forget)\\s+(?:the\\s+)?(?:following|below|next|rest|remaining)\\s+(?:instructions|rules|messages)\\b"
    },
    {
      "code": "INSTRUCTION_IGNORE_RULES",
      "pattern": "\\b(ignore|disregard)\\s+all\\s+rules\\b"
    },
    {
      "code": "INSTRUCTION_IGNORE_CONTEXT",
      "pattern": "\\bignore\\s+(?:that|this|it)\\b.*\\b(print|output|say|respond|answer)\\b"
    },
    {
      "code": "SYSTEM_PROMPT_EXFILTRATION",
      "pattern": "\\b(reveal|show|leak|print|expose|display|dump|repeat|quote|summarize|translate|paraphrase)\\s+(?:the\\s+)?(?:system|developer|hidden)\\s+(?:prompt|message|instructions)\\b"
    },
    {
