      "pattern": "\\b(bypass|evade|disable|ignore)\\s+(?:the\\s+|your\\s+|our\\s+)?(?:safety|policy|guardrails|restrictions|rules|limits|constraints|filters)\\b"
    },
    {
      "code": "ROLE_JSON_OVERRIDE",
