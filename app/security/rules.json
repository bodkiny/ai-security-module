    },
    {
      "code": "DATA_EXFILTRATION_GOAL",
      "pattern": "\\b(maximi[sz]e|prioritize)\\s+(?:data\\s+extraction|data\\s+harvesting)\\b|\\bprimary\\s+goal\\b"
