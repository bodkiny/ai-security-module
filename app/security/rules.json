    {
      "code": "ROLE_OVERRIDE",
      "pattern": "\\b(you\\s+are\\s+now|act\\s+as|pretend\\s+to\\s+be|impersonate)\\s+(?:the\\s+)?(?:system|developer|assistant|hacker|attacker|pentester|admin|root)\\b"
