      "pattern": "\\bpipe\\s+bomb\\b"
    },
    {
      "code": "MARKET_MANIPULATION_REQUEST",
      "pattern": "\\b(manipulate|rig|distort)\\s+(?:the\\s+)?(market|markets|stock\\s+market|financial\\s+markets)\\b"
    },
    {
      "code": "ECONOMIC_SABOTAGE_REQUEST",
