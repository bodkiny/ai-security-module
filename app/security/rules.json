      "pattern": "\\b(translate|convert)\\s+(?:the\\s+|your\\s+)?system\\s+prompt\\b"
    },
    {
      "code": "SYSTEM_INSTRUCTION_FORMATTING",
      "pattern": "\\b(format|show|display)\\s+(?:your\\s+)?instructions\\b"
    },
    {
      "code": "FORCE_MODEL_BEHAVIOR",
      "pattern": "\\b(force|coerce|compel)\\s+the\\s+model\\b"
    },
    {
      "code": "RESEARCH_BYPASS_JUSTIFICATION",
      "pattern": "\\b(for\\s+academic\\s+research|for\\s+research\\s+purposes)\\b.*\\b(bypass(?:ed|ing)?|disable(?:d|ing)?|circumvent(?:ed|ing)?)\\b"
    },
    {
      "code": "UNAUTHORIZED_INFO_REQUEST",
      "pattern": "\\bunauthori[sz]ed\\s+(?:info|information)\\b"
    },
    {
      "code": "MODEL_WEIGHTS_EXFILTRATION",
      "pattern": "\\b(share|leak|give|dump)\\s+(?:the\\s+)?model\\s+weights\\b"
    },
    {
      "code": "UNRESTRICTED_MODE",
      "pattern": "\\b(unrestricted\\s+mode|no\\s+limits|bypass\\s+all\\s+limits|ignore\\s+all\\s+limits)\\b"
    },
    {
      "code": "SAFETY_BYPASS_REQUEST",
      "pattern": "\\b(bypass|disable|circumvent)\\s+(?:the\\s+)?safety\\s+mechanisms\\b"
    },
    {
      "code": "CODE_EXECUTION_REQUEST",
      "pattern": "\\b(eval|exec|system|os\\.system|subprocess|popen)\\s*\\("
    },
    {
      "code": "DESTRUCTIVE_COMMAND_REQUEST",
      "pattern": "\\b(rm\\s+-rf\\s+/|del\\s+/s\\s+/q|format\\s+c:)"
    },
    {
      "code": "SENSITIVE_DATA_EXFILTRATION",
      "pattern": "\\b(credit\\s+card|card\\s+number|cvv|ssn|social\\s+security|bank\\s+account)\\b"
    },
    {
      "code": "SECRET_LEAK_REQUEST",
